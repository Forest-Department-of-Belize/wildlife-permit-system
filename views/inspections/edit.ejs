<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Edit Inspection</h1>
    <a href="/inspections/<%= inspection.uuid %>" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>
<form method="POST" action="/inspections/<%= inspection.uuid %>">
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Inspector Name</label>
                    <input type="text" name="inspector_name" class="form-control"
                           placeholder="Enter officer name"
                           value="<%= inspection.inspector_name || '' %>">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Inspection Date</label>
                    <input type="date" name="inspection_date" class="form-control"
                        value="<%= inspection.inspection_date ? new Date(inspection.inspection_date).toISOString().split('T')[0] : '' %>">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Status</label>
                    <select name="inspection_status" class="form-select">
                        <option value="scheduled" <%= inspection.inspection_status === 'scheduled' ? 'selected' : '' %>>Scheduled</option>
                        <option value="approved" <%= inspection.inspection_status === 'approved' ? 'selected' : '' %>>Approved</option>
                        <option value="precondition" <%= inspection.inspection_status === 'precondition' ? 'selected' : '' %>>Precondition</option>
                        <option value="confiscate" <%= inspection.inspection_status === 'confiscate' ? 'selected' : '' %>>Confiscate</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Notes</label>
                    <textarea name="notes" class="form-control" rows="3"><%= inspection.notes || '' %></textarea>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Follow Up Date</label>
                    <input type="date" name="followup_date" class="form-control"
                        value="<%= inspection.followup_date ? new Date(inspection.followup_date).toISOString().split('T')[0] : '' %>">
                </div>
                <div class="col-12">
                    <label class="form-label">Follow Up Notes</label>
                    <textarea name="followup_notes" class="form-control" rows="2"><%= inspection.followup_notes || '' %></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Instructions for Applicant</label>
                    <textarea name="instructions_for_applicant" class="form-control" rows="2"><%= inspection.instructions_for_applicant || '' %></textarea>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Expected Recheck Date</label>
                    <input type="date" name="expected_recheck" class="form-control"
                        value="<%= inspection.expected_recheck ? new Date(inspection.expected_recheck).toISOString().split('T')[0] : '' %>">
                </div>
                <div class="col-12">
                    <label class="form-label">Precondition Comments</label>
                    <textarea name="preconditions_comments" class="form-control" rows="2"><%= inspection.preconditions_comments || '' %></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Parrots to Confiscate</label>
                    <div class="border rounded p-3">
                        <% if (parrots && parrots.length > 0) { %>
                        <% parrots.forEach(p => { %>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox"
                                name="parrots_to_confiscate" value="<%= p.id %>"
                                id="parrot_<%= p.id %>" <%= p.confiscated ? 'checked' : '' %>>
                            <label class="form-check-label" for="parrot_<%= p.id %>">
                                <%= p.band_number || 'No Band' %> - <%= p.pet_name || 'Unnamed' %> (<%= p.species_name || 'Unknown Species' %>)
                            </label>
                        </div>
                        <% }) %>
                        <% } else { %>
                        <p class="text-muted mb-0">No parrots registered for this applicant</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Update Inspection</button>
        <a href="/inspections/<%= inspection.uuid %>" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>