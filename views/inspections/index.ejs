
<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Inspections</h1>
        <p class="text-muted mb-0"><%= inspections.length %> records found</p>
    </div>
    <% if (user && user.permissions && user.permissions.includes('inspections-add')) { %>
    <a href="/inspections/create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Schedule Inspection</a>
    <% } %>
</div>
<div class="card">
    <div class="card-body">
        <div class="mb-3">
            <input type="text" id="searchInput" class="form-control" placeholder="Search inspections...">
        </div>
        <div class="table-responsive">
            <table class="table table-hover" id="dataTable">
                <thead>
                    <tr><th>Date</th><th>Applicant</th><th>Inspector</th><th>Status</th><th>Follow Up</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    <% inspections.forEach(i => { %>
                    <tr>
                        <td><%= i.inspection_date ? new Date(i.inspection_date).toLocaleDateString() : '-' %></td>
                        <td><a href="/applicants/<%= i.applicant_uuid %>"><%= i.applicant_name || '-' %></a></td>
                        <td><%= i.inspector_name || '-' %></td>
                        <td>
                            <span class="badge bg-<%= i.inspection_status === 'approved' ? 'success' : i.inspection_status === 'scheduled' ? 'warning' : i.inspection_status === 'confiscate' ? 'danger' : 'secondary' %>">
                                <%= i.inspection_status %>
                            </span>
                        </td>
                        <td><%= i.followup_date ? new Date(i.followup_date).toLocaleDateString() : '-' %></td>
                        <td>
                            <a href="/inspections/<%= i.uuid %>" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a>
                            <% if (user && user.permissions && user.permissions.includes('inspections-edit')) { %>
                            <a href="/inspections/<%= i.uuid %>/edit" class="btn btn-sm btn-outline-secondary"><i class="fas fa-edit"></i></a>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (inspections.length === 0) { %>
                    <tr><td colspan="6" class="text-center text-muted py-4">No inspections found</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<script>
document.getElementById('searchInput').addEventListener('keyup', function() {
    const value = this.value.toLowerCase();
    document.querySelectorAll('#dataTable tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(value) ? '' : 'none';
    });
});
</script>