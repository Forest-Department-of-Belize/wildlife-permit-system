<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Inspections</h1>
        <p class="text-muted mb-0"><%= inspections.length %> records found</p>
    </div>
    <div class="d-flex gap-2">
        <div class="btn-group" role="group">
            <button type="button" class="btn btn-outline-secondary active" id="btnListView">
                <i class="fas fa-list"></i> List
            </button>
            <button type="button" class="btn btn-outline-secondary" id="btnCalView">
                <i class="fas fa-calendar-alt"></i> Calendar
            </button>
        </div>
        <% if (user && user.permissions && user.permissions.includes('inspections-add')) { %>
        <a href="/inspections/create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Schedule</a>
        <% } %>
    </div>
</div>

<!-- Search (list only) -->
<div id="listSearch" class="mb-3">
    <form method="GET" action="/inspections" class="d-flex gap-2">
        <input type="text" name="search" class="form-control"
               placeholder="Search by applicant name or status..."
               value="<%= search %>">
        <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
        <% if (search) { %>
        <a href="/inspections" class="btn btn-outline-secondary"><i class="fas fa-times"></i></a>
        <% } %>
    </form>
</div>

<!-- LIST VIEW -->
<div id="listView">
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr><th>Date</th><th>Applicant</th><th>Inspector</th><th>Status</th><th>Follow Up</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        <% inspections.forEach(i => { %>
                        <tr>
                            <td><%= i.inspection_date ? new Date(i.inspection_date).toLocaleDateString() : '-' %></td>
                            <td><a href="/applicants/<%= i.applicant_uuid %>"><%= i.applicant_name || '-' %></a></td>
                            <td><%= i.inspector_name || '-' %></td>
                            <td>
                                <span class="badge bg-<%= i.inspection_status === 'approved' ? 'success' : i.inspection_status === 'scheduled' ? 'warning' : i.inspection_status === 'confiscate' ? 'danger' : 'secondary' %>">
                                    <%= i.inspection_status %>
                                </span>
                            </td>
                            <td><%= i.followup_date ? new Date(i.followup_date).toLocaleDateString() : '-' %></td>
                            <td>
                                <a href="/inspections/<%= i.uuid %>" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a>
                                <% if (user && user.permissions && user.permissions.includes('inspections-edit')) { %>
                                <a href="/inspections/<%= i.uuid %>/edit" class="btn btn-sm btn-outline-secondary"><i class="fas fa-edit"></i></a>
                                <% } %>
                            </td>
                        </tr>
                        <% }) %>
                        <% if (inspections.length === 0) { %>
                        <tr><td colspan="6" class="text-center text-muted py-4">No inspections found</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- CALENDAR VIEW -->
<div id="calView" style="display:none">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <button class="btn btn-outline-secondary btn-sm" id="calPrev"><i class="fas fa-chevron-left"></i> Prev</button>
                <h5 class="mb-0" id="calTitle"></h5>
                <button class="btn btn-outline-secondary btn-sm" id="calNext">Next <i class="fas fa-chevron-right"></i></button>
            </div>
            <div id="calGrid"></div>
            <div class="d-flex gap-3 mt-3 flex-wrap">
                <span><span class="badge bg-warning">●</span> Scheduled</span>
                <span><span class="badge bg-success">●</span> Approved</span>
                <span><span class="badge bg-danger">●</span> Confiscate</span>
                <span><span class="badge bg-secondary">●</span> Other</span>
            </div>
        </div>
    </div>
    <div id="calPopup" class="card shadow-lg" style="display:none;position:fixed;z-index:9999;min-width:260px;max-width:340px;top:50%;left:50%;transform:translate(-50%,-50%)">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong id="popupTitle">Inspection</strong>
            <button class="btn-close btn-sm" id="popupClose"></button>
        </div>
        <div class="card-body" id="popupBody"></div>
    </div>
    <div id="calBackdrop" style="display:none;position:fixed;inset:0;z-index:9998;background:rgba(0,0,0,0.3)"></div>
</div>

<script>
var inspectionEvents = <%- JSON.stringify(inspections.map(function(i) { return {
    uuid: i.uuid,
    date: i.inspection_date,
    applicant: i.applicant_name,
    applicant_uuid: i.applicant_uuid,
    inspector: i.inspector_name || '',
    status: i.inspection_status,
    followup: i.followup_date
}; })) %>;

var listView   = document.getElementById('listView');
var calView    = document.getElementById('calView');
var listSearch = document.getElementById('listSearch');
var btnList    = document.getElementById('btnListView');
var btnCal     = document.getElementById('btnCalView');

function showList() {
    listView.style.display = '';
    listSearch.style.display = '';
    calView.style.display = 'none';
    btnList.classList.add('active');
    btnCal.classList.remove('active');
}

function showCal() {
    listView.style.display = 'none';
    listSearch.style.display = 'none';
    calView.style.display = '';
    btnCal.classList.add('active');
    btnList.classList.remove('active');
    renderCal();
}

btnList.addEventListener('click', showList);
btnCal.addEventListener('click', showCal);

var calYear  = new Date().getFullYear();
var calMonth = new Date().getMonth();
var today    = new Date();

var STATUS_COLORS = {
    scheduled:  '#FFC107',
    approved:   '#2E7D32',
    confiscate: '#C62828',
    completed:  '#1565C0'
};

function getColor(status) {
    return STATUS_COLORS[status] || '#607D8B';
}

function renderCal() {
    var title = document.getElementById('calTitle');
    var grid  = document.getElementById('calGrid');
    var monthNames = ['January','February','March','April','May','June',
                      'July','August','September','October','November','December'];
    title.textContent = monthNames[calMonth] + ' ' + calYear;

    var firstDay  = new Date(calYear, calMonth, 1).getDay();
    var daysInMon = new Date(calYear, calMonth + 1, 0).getDate();

    var evMap = {};
    inspectionEvents.forEach(function(ev) {
        if (!ev.date) return;
        var d   = new Date(ev.date);
        var key = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
        if (!evMap[key]) evMap[key] = [];
        evMap[key].push(ev);
    });

    var dayAbbr = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    var html = '<div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px">';
    dayAbbr.forEach(function(d) {
        html += '<div style="text-align:center;font-weight:600;font-size:12px;padding:6px 0;color:#555">' + d + '</div>';
    });

    for (var b = 0; b < firstDay; b++) {
        html += '<div style="min-height:80px;background:#f8f9fa;border-radius:4px"></div>';
    }

    for (var day = 1; day <= daysInMon; day++) {
        var key = calYear + '-' + String(calMonth+1).padStart(2,'0') + '-' + String(day).padStart(2,'0');
        var evs = evMap[key] || [];
        var isToday = (day === today.getDate() && calMonth === today.getMonth() && calYear === today.getFullYear());
        var bgCell = isToday ? '#e8f5e9' : '#fff';
        var borderCell = isToday ? '2px solid #2E7D32' : '1px solid #e0e0e0';

        var evHtml = evs.slice(0,3).map(function(ev) {
            var col  = getColor(ev.status);
            var name = (ev.applicant || '').split(' ').pop();
            return '<div onclick="showPopup(\'' + ev.uuid + '\')" style="background:' + col + ';color:#fff;border-radius:3px;padding:1px 4px;font-size:11px;margin-top:2px;cursor:pointer;overflow:hidden;white-space:nowrap;text-overflow:ellipsis">' + name + '</div>';
        }).join('');

        if (evs.length > 3) {
            evHtml += '<div style="font-size:10px;color:#888;margin-top:2px">+' + (evs.length - 3) + ' more</div>';
        }

        html += '<div style="min-height:80px;background:' + bgCell + ';border:' + borderCell + ';border-radius:4px;padding:4px">';
        html += '<span style="font-size:12px;font-weight:' + (isToday?'700':'400') + ';color:' + (isToday?'#2E7D32':'#333') + '">' + day + '</span>';
        html += evHtml + '</div>';
    }

    html += '</div>';
    grid.innerHTML = html;
}

function showPopup(uuid) {
    var ev = null;
    for (var i = 0; i < inspectionEvents.length; i++) {
        if (inspectionEvents[i].uuid === uuid) { ev = inspectionEvents[i]; break; }
    }
    if (!ev) return;
    var statusBadge = { scheduled:'warning', approved:'success', confiscate:'danger', completed:'primary' };
    var col   = statusBadge[ev.status] || 'secondary';
    var idate = ev.date    ? new Date(ev.date).toLocaleDateString()    : '—';
    var fdate = ev.followup ? new Date(ev.followup).toLocaleDateString() : '—';
    document.getElementById('popupTitle').textContent = ev.applicant || 'Inspection';
    document.getElementById('popupBody').innerHTML =
        '<table class="table table-sm table-borderless mb-2">' +
        '<tr><td class="text-muted">Date</td><td><strong>' + idate + '</strong></td></tr>' +
        '<tr><td class="text-muted">Inspector</td><td>' + (ev.inspector || '—') + '</td></tr>' +
        '<tr><td class="text-muted">Status</td><td><span class="badge bg-' + col + '">' + ev.status + '</span></td></tr>' +
        '<tr><td class="text-muted">Follow Up</td><td>' + fdate + '</td></tr>' +
        '</table>' +
        '<a href="/inspections/' + ev.uuid + '" class="btn btn-sm btn-outline-primary w-100"><i class="fas fa-eye me-1"></i>View Full Record</a>';
    document.getElementById('calPopup').style.display = '';
    document.getElementById('calBackdrop').style.display = '';
}

document.getElementById('popupClose').addEventListener('click', function() {
    document.getElementById('calPopup').style.display = 'none';
    document.getElementById('calBackdrop').style.display = 'none';
});
document.getElementById('calBackdrop').addEventListener('click', function() {
    document.getElementById('calPopup').style.display = 'none';
    document.getElementById('calBackdrop').style.display = 'none';
});
document.getElementById('calPrev').addEventListener('click', function() {
    calMonth--;
    if (calMonth < 0) { calMonth = 11; calYear--; }
    renderCal();
});
document.getElementById('calNext').addEventListener('click', function() {
    calMonth++;
    if (calMonth > 11) { calMonth = 0; calYear++; }
    renderCal();
});
</script>