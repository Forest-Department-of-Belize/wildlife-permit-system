<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Inspections</h1>
        <p class="text-muted mb-0"><%= inspections.length %> records found</p>
    </div>
    <div class="d-flex gap-2">
        <div class="btn-group" role="group">
            <a href="/inspections?view=list" class="btn btn-outline-secondary <%= view !== 'cal' ? 'active' : '' %>">
                <i class="fas fa-list"></i> List
            </a>
            <a href="/inspections?view=cal" class="btn btn-outline-secondary <%= view === 'cal' ? 'active' : '' %>">
                <i class="fas fa-calendar-alt"></i> Calendar
            </a>
        </div>
        <% if (user && user.permissions && user.permissions.includes('inspections-add')) { %>
        <a href="/inspections/create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Schedule</a>
        <% } %>
    </div>
</div>

<% if (view !== 'cal') { %>
<!-- LIST VIEW -->
<div class="mb-3">
    <form method="GET" action="/inspections" class="d-flex gap-2">
        <input type="hidden" name="view" value="list">
        <input type="text" name="search" class="form-control"
               placeholder="Search by applicant name or status..."
               value="<%= search %>">
        <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
        <% if (search) { %>
        <a href="/inspections" class="btn btn-outline-secondary"><i class="fas fa-times"></i></a>
        <% } %>
    </form>
</div>
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr><th>Date</th><th>Applicant</th><th>Inspector</th><th>Status</th><th>Follow Up</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    <% inspections.forEach(i => { %>
<tr style="cursor:pointer;" ondblclick="window.location='/inspections/<%= i.uuid %>'">
                        <td><%= i.inspection_date ? new Date(i.inspection_date).toLocaleDateString() : '-' %></td>
                        <td><a href="/applicants/<%= i.applicant_uuid %>"><%= i.applicant_name || '-' %></a></td>
                        <td><%= i.inspector_name || '-' %></td>
                        <td>
                            <span class="badge bg-<%= i.inspection_status === 'approved' ? 'success' : i.inspection_status === 'scheduled' ? 'warning' : i.inspection_status === 'confiscate' ? 'danger' : 'secondary' %>">
                                <%= i.inspection_status %>
                            </span>
                        </td>
                        <td><%= i.followup_date ? new Date(i.followup_date).toLocaleDateString() : '-' %></td>
                        <td>
                            <a href="/inspections/<%= i.uuid %>" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a>
                            <% if (user && user.permissions && user.permissions.includes('inspections-edit')) { %>
                            <a href="/inspections/<%= i.uuid %>/edit" class="btn btn-sm btn-outline-secondary"><i class="fas fa-edit"></i></a>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (inspections.length === 0) { %>
                    <tr><td colspan="6" class="text-center text-muted py-4">No inspections found</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<% } else { %>
<!-- CALENDAR VIEW -->
<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <a href="/inspections?view=cal&month=<%= prevMonth %>&year=<%= prevYear %>" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-chevron-left"></i> Prev
            </a>
            <h5 class="mb-0"><%= monthName %> <%= calYear %></h5>
            <a href="/inspections?view=cal&month=<%= nextMonth %>&year=<%= nextYear %>" class="btn btn-outline-secondary btn-sm">
                Next <i class="fas fa-chevron-right"></i>
            </a>
        </div>

        <!-- Calendar Grid -->
        <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;">
            <% ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].forEach(d => { %>
            <div style="text-align:center;font-weight:600;font-size:12px;padding:6px 0;color:#555;"><%= d %></div>
            <% }) %>

            <% for(let b = 0; b < firstDay; b++) { %>
            <div style="min-height:80px;background:#f8f9fa;border-radius:4px;"></div>
            <% } %>

            <% for(let day = 1; day <= daysInMonth; day++) {
                const key = calYear + '-' + String(calMonth).padStart(2,'0') + '-' + String(day).padStart(2,'0');
                const dayEvents = calEvents[key] || [];
                const isToday = (day === todayDay && calMonth == todayMonth && calYear == todayYear);
            %>
            <div style="min-height:80px;background:<%= isToday ? '#e8f5e9' : '#fff' %>;border:<%= isToday ? '2px solid #2E7D32' : '1px solid #e0e0e0' %>;border-radius:4px;padding:4px;">
                <span style="font-size:12px;font-weight:<%= isToday ? '700' : '400' %>;color:<%= isToday ? '#2E7D32' : '#333' %>"><%= day %></span>
                <% dayEvents.slice(0,3).forEach(ev => { %>
                <a href="/inspections/<%= ev.uuid %>" style="display:block;background:<%= ev.color %>;color:#fff;border-radius:3px;padding:1px 4px;font-size:11px;margin-top:2px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;text-decoration:none;">
                    <%= ev.applicant %>
                </a>
                <% }) %>
                <% if (dayEvents.length > 3) { %>
                <div style="font-size:10px;color:#888;margin-top:2px;">+<%= dayEvents.length - 3 %> more</div>
                <% } %>
            </div>
            <% } %>
        </div>

        <!-- Legend -->
        <div class="d-flex gap-3 mt-3 flex-wrap">
            <span><span class="badge bg-warning">●</span> Scheduled</span>
            <span><span class="badge bg-success">●</span> Approved</span>
            <span><span class="badge bg-danger">●</span> Confiscate</span>
            <span><span class="badge bg-secondary">●</span> Other</span>
        </div>
    </div>
</div>
<% } %>