<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Log New Call</h1>
    <a href="<%= locals.applicantUuid ? '/applicants/' + locals.applicantUuid : '/calls' %>" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i>Back
    </a>
</div>
<form method="POST" action="/calls">
    <input type="hidden" name="applicant_uuid" value="<%= locals.applicantUuid || '' %>">
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Applicant <span class="text-danger">*</span></label>
                    <% if (locals.preselectedApplicant) { %>
                    <input type="hidden" name="applicant_id" value="<%= preselectedApplicant.id %>">
                    <input type="text" class="form-control" value="<%= preselectedApplicant.last_name %>, <%= preselectedApplicant.first_name %>" disabled>
                    <% } else { %>
                    <select name="applicant_id" class="form-select" required>
                        <option value="">Select Applicant</option>
                        <% applicants.forEach(a => { %>
                        <option value="<%= a.id %>"><%= a.last_name %>, <%= a.first_name %></option>
                        <% }) %>
                    </select>
                    <% } %>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Officer Name</label>
                    <input type="text" name="officer_name" class="form-control"
                           value="<%= user.first_name + ' ' + user.last_name %>"
                           placeholder="Enter officer name">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Number Called</label>
                    <input type="text" name="number_called" class="form-control">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Call Date</label>
                    <input type="date" name="call_date" class="form-control">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Language</label>
                    <select name="language" class="form-select">
                        <option value="">Select Language</option>
                        <option value="English">English</option>
                        <option value="Spanish">Spanish</option>
                        <option value="Creole">Creole</option>
                        <option value="Garifuna">Garifuna</option>
                        <option value="Maya">Maya</option>
                    </select>
                </div>
                <div class="col-12">
                    <div class="row g-2">
                        <div class="col-6 col-md-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="is_functional" id="isFunctional">
                                <label class="form-check-label" for="isFunctional">Functional</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="is_answered" id="isAnswered">
                                <label class="form-check-label" for="isAnswered">Answered</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="is_applicant" id="isApplicant">
                                <label class="form-check-label" for="isApplicant">Was Applicant</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="is_fully_completed" id="isCompleted">
                                <label class="form-check-label" for="isCompleted">Fully Completed</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="call_now_consent" id="callNow">
                                <label class="form-check-label" for="callNow">Consent to Call</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="call_later_consent" id="callLater">
                                <label class="form-check-label" for="callLater">Call Later Consent</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="consents_digital_resources" id="digitalConsent">
                                <label class="form-check-label" for="digitalConsent">Digital Resources Consent</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Call Later Date</label>
                    <input type="date" name="call_later_date" class="form-control">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Neighbors with Parrots</label>
                    <input type="number" name="num_neighbors_parrots" class="form-control" min="0">
                </div>
                <div class="col-12">
                    <label class="form-label">Neighborhood Description</label>
                    <textarea name="neighborhood_description" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Call Comments</label>
                    <textarea name="call_comments" class="form-control" rows="3"></textarea>
                </div>
            </div>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Save Call</button>
        <a href="<%= locals.applicantUuid ? '/applicants/' + locals.applicantUuid : '/calls' %>" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>