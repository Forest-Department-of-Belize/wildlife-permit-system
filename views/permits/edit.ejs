
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Edit Permit</h1>
    <a href="/permits/<%= permit.uuid %>" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i>Back
    </a>
</div>

<form method="POST" action="/permits/<%= permit.uuid %>">
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Forest Station</label>
                    <select name="range_id" class="form-select">
                        <% ranges.forEach(r => { %>
                        <option value="<%= r.id %>" <%= permit.range_id == r.id ? 'selected' : '' %>><%= r.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Permit Number</label>
                    <input type="text" name="permit_number" class="form-control" value="<%= permit.permit_number || '' %>">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Reference Number</label>
                    <input type="text" name="reference_number" class="form-control" value="<%= permit.reference_number || '' %>">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Application Date</label>
                    <input type="date" name="application_date" class="form-control"
                        value="<%= permit.application_date ? new Date(permit.application_date).toISOString().split('T')[0] : '' %>">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Issue Date</label>
                    <input type="date" name="issue_date" class="form-control"
                        value="<%= permit.issue_date ? new Date(permit.issue_date).toISOString().split('T')[0] : '' %>">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Number of Pets</label>
                    <input type="number" name="number_of_pets" class="form-control" value="<%= permit.number_of_pets || 0 %>">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-select">
                        <option value="Processing" <%= permit.status === 'Processing' ? 'selected' : '' %>>Processing</option>
                        <option value="Active" <%= permit.status === 'Active' ? 'selected' : '' %>>Active</option>
                        <option value="Inactive" <%= permit.status === 'Inactive' ? 'selected' : '' %>>Inactive</option>
                        <option value="Suspended" <%= permit.status === 'Suspended' ? 'selected' : '' %>>Suspended</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Housing Description</label>
                    <textarea name="housing" class="form-control" rows="3"><%= permit.housing || '' %></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Permit Picture URL</label>
                    <input type="text" name="picture_url" class="form-control" value="<%= permit.picture_url || '' %>">
                </div>
                <div class="col-12">
                    <label class="form-label">Comments</label>
                    <textarea name="permit_comments" class="form-control" rows="2"><%= permit.permit_comments || '' %></textarea>
                </div>
            </div>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save me-2"></i>Update Permit
        </button>
        <a href="/permits/<%= permit.uuid %>" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>