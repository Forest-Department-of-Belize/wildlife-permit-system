<%- include('../layouts/main') %>
<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Permit: <%= permit.permit_number || 'N/A' %></h1>
        <p class="text-muted mb-0">Permit Record</p>
    </div>
    <div>
        <% if (user && user.permissions && user.permissions.includes('permits-edit')) { %>
        <a href="/permits/<%= permit.uuid %>/edit" class="btn btn-outline-secondary me-2">
            <i class="fas fa-edit me-1"></i>Edit
        </a>
        <% } %>
        <a href="/permits" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-lg-6">
        <div class="card">
            <div class="card-header"><h6 class="mb-0">Permit Details</h6></div>
            <div class="card-body">
                <table class="table table-borderless table-sm mb-0">
                    <tr><td class="text-muted">Permit Number</td><td><strong><%= permit.permit_number || '-' %></strong></td></tr>
                    <tr><td class="text-muted">Reference Number</td><td><%= permit.reference_number || '-' %></td></tr>
                    <tr><td class="text-muted">Applicant</td>
                        <td><a href="/applicants/<%= permit.applicant_uuid %>"><%= permit.applicant_name || '-' %></a></td></tr>
                    <tr><td class="text-muted">Forest Station</td><td><%= permit.range_name || '-' %></td></tr>
                    <tr><td class="text-muted">Application Date</td>
                        <td><%= permit.application_date ? new Date(permit.application_date).toLocaleDateString() : '-' %></td></tr>
                    <tr><td class="text-muted">Issue Date</td>
                        <td><%= permit.issue_date ? new Date(permit.issue_date).toLocaleDateString() : '-' %></td></tr>
                    <tr><td class="text-muted">Number of Pets</td><td><%= permit.number_of_pets || 0 %></td></tr>
                    <tr><td class="text-muted">Housing</td><td><%= permit.housing || '-' %></td></tr>
                    <tr><td class="text-muted">Status</td>
                        <td>
                            <span class="badge bg-<%= permit.status === 'Active' ? 'success' : permit.status === 'Processing' ? 'warning' : permit.status === 'Suspended' ? 'danger' : 'secondary' %>">
                                <%= permit.status || '-' %>
                            </span>
                        </td>
                    </tr>
                    <% if (permit.picture_url) { %>
                    <tr><td class="text-muted">Permit Picture</td>
                        <td><a href="<%= permit.picture_url %>" target="_blank">View Picture</a></td></tr>
                    <% } %>
                    <% if (permit.permit_comments) { %>
                    <tr><td class="text-muted">Comments</td><td><%= permit.permit_comments %></td></tr>
                    <% } %>
                </table>
            </div>
        </div>
    </div>
</div>