<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Permits</h1>
        <p class="text-muted mb-0"><%= total %> records found — showing page <%= page %> of <%= totalPages %></p>
    </div>
    <% if (user && user.permissions && user.permissions.includes('permits-add')) { %>
    <a href="/permits/create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Add Permit
    </a>
    <% } %>
</div>

<div class="card">
    <div class="card-body">
        <div class="mb-3">
            <form method="GET" action="/permits" class="row g-2">
                <div class="col-12 col-md-4">
                    <input type="text" name="search" class="form-control"
                           placeholder="Search by permit number, reference or applicant..."
                           value="<%= search %>">
                </div>
                <div class="col-6 col-md-2">
                    <select name="status" class="form-select">
                        <option value="">All Statuses</option>
                        <option value="Active" <%= locals.status == 'Active' ? 'selected' : '' %>>Active</option>
                        <option value="Processing" <%= locals.status == 'Processing' ? 'selected' : '' %>>Processing</option>
                        <option value="Suspended" <%= locals.status == 'Suspended' ? 'selected' : '' %>>Suspended</option>
                        <option value="Inactive" <%= locals.status == 'Inactive' ? 'selected' : '' %>>Inactive</option>
                        <option value="Expired" <%= locals.status == 'Expired' ? 'selected' : '' %>>Expired</option>
                    </select>
                </div>
                <input type="hidden" name="sort" value="<%= sort %>">
                <input type="hidden" name="dir" value="<%= dir %>">
                <div class="col-6 col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-filter me-1"></i>Filter
                    </button>
                </div>
                <div class="col-6 col-md-2">
                    <a href="/permits" class="btn btn-outline-secondary w-100">
                        <i class="fas fa-times me-1"></i>Clear
                    </a>
                </div>
            </form>
        </div>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>
                            <a href="/permits?page=1&search=<%= search %>&sort=permit_number&dir=<%= sort === 'permit_number' && dir === 'asc' ? 'desc' : 'asc' %>" class="text-dark text-decoration-none">
                                Permit No. <i class="fas fa-sort<%= sort === 'permit_number' ? (dir === 'asc' ? '-up' : '-down') : '' %> ms-1"></i>
                            </a>
                        </th>
                        <th>
                            <a href="/permits?page=1&search=<%= search %>&sort=applicant_name&dir=<%= sort === 'applicant_name' && dir === 'asc' ? 'desc' : 'asc' %>" class="text-dark text-decoration-none">
                                Applicant <i class="fas fa-sort<%= sort === 'applicant_name' ? (dir === 'asc' ? '-up' : '-down') : '' %> ms-1"></i>
                            </a>
                        </th>
                        <th>Reference</th>
                        <th>
                            <a href="/permits?page=1&search=<%= search %>&sort=range_name&dir=<%= sort === 'range_name' && dir === 'asc' ? 'desc' : 'asc' %>" class="text-dark text-decoration-none">
                                Station <i class="fas fa-sort<%= sort === 'range_name' ? (dir === 'asc' ? '-up' : '-down') : '' %> ms-1"></i>
                            </a>
                        </th>
                        <th>
                            <a href="/permits?page=1&search=<%= search %>&sort=issue_date&dir=<%= sort === 'issue_date' && dir === 'asc' ? 'desc' : 'asc' %>" class="text-dark text-decoration-none">
                                Issue Date <i class="fas fa-sort<%= sort === 'issue_date' ? (dir === 'asc' ? '-up' : '-down') : '' %> ms-1"></i>
                            </a>
                        </th>
                        <th>
                            <a href="/permits?page=1&search=<%= search %>&sort=status&dir=<%= sort === 'status' && dir === 'asc' ? 'desc' : 'asc' %>" class="text-dark text-decoration-none">
                                Status <i class="fas fa-sort<%= sort === 'status' ? (dir === 'asc' ? '-up' : '-down') : '' %> ms-1"></i>
                            </a>
                        </th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% permits.forEach(p => { %>
                    <tr style="cursor:pointer;" ondblclick="window.location='/permits/<%= p.uuid %>'">
                        <td><%= p.permit_number || '-' %></td>
                        <td>
                            <% if (p.applicant_uuid) { %>
                                <a href="/applicants/<%= p.applicant_uuid %>" class="text-decoration-none"><%= p.applicant_name || '-' %></a>
                            <% } else { %>
                                <%= p.applicant_name || '-' %>
                            <% } %>
                        </td>
                        <td><%= p.reference_number || '-' %></td>
                        <td><%= p.range_name || '-' %></td>
                        <td><%= p.issue_date ? new Date(p.issue_date).toLocaleDateString() : '-' %></td>
                        <td>
                            <span class="badge bg-<%= p.status === 'Active' ? 'success' : p.status === 'Processing' ? 'warning' : p.status === 'Suspended' ? 'danger' : 'secondary' %>">
                                <%= p.status || '-' %>
                            </span>
                        </td>
                        <td>
                            <a href="/permits/<%= p.uuid %>" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye"></i>
                            </a>
                            <% if (user && user.permissions && user.permissions.includes('permits-edit')) { %>
                            <a href="/permits/<%= p.uuid %>/edit" class="btn btn-sm btn-outline-secondary">
                                <i class="fas fa-edit"></i>
                            </a>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (permits.length === 0) { %>
                    <tr><td colspan="7" class="text-center text-muted py-4">No permits found</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <% if (totalPages > 1) { %>
        <nav class="mt-3">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="/permits?page=<%= page - 1 %>&search=<%= search %>&sort=<%= sort %>&dir=<%= dir %>&status=<%= locals.status || '' %>">
                        <i class="fas fa-chevron-left"></i> Prev
                    </a>
                </li>
                <% for (let i = Math.max(1, page - 2); i <= Math.min(totalPages, page + 2); i++) { %>
                <li class="page-item <%= i === page ? 'active' : '' %>">
                    <a class="page-link" href="/permits?page=<%= i %>&search=<%= search %>&sort=<%= sort %>&dir=<%= dir %>&status=<%= locals.status || '' %>"><%= i %></a>
                </li>
                <% } %>
                <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
                    <a class="page-link" href="/permits?page=<%= page + 1 %>&search=<%= search %>&sort=<%= sort %>&dir=<%= dir %>&status=<%= locals.status || '' %>">
                        Next <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
            <p class="text-center text-muted small mt-2">
                Showing <%= (page - 1) * 30 + 1 %> — <%= Math.min(page * 30, total) %> of <%= total %> permits
            </p>
        </nav>
        <% } %>
    </div>
</div>