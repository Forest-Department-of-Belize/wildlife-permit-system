<%- include('../layouts/main') %>
<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Permits</h1>
        <p class="text-muted mb-0"><%= permits.length %> records found</p>
    </div>
    <% if (user && user.permissions && user.permissions.includes('permits-add')) { %>
    <a href="/permits/create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Add Permit
    </a>
    <% } %>
</div>

<div class="card">
    <div class="card-body">
        <div class="mb-3">
            <input type="text" id="searchInput" class="form-control" placeholder="Search permits...">
        </div>
        <div class="table-responsive">
            <table class="table table-hover" id="permitsTable">
                <thead>
                    <tr>
                        <th>Permit No.</th>
                        <th>Applicant</th>
                        <th>Reference</th>
                        <th>Station</th>
                        <th>Issue Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% permits.forEach(p => { %>
                    <tr>
                        <td><%= p.permit_number || '-' %></td>
                        <td><%= p.applicant_name || '-' %></td>
                        <td><%= p.reference_number || '-' %></td>
                        <td><%= p.range_name || '-' %></td>
                        <td><%= p.issue_date ? new Date(p.issue_date).toLocaleDateString() : '-' %></td>
                        <td>
                            <span class="badge bg-<%= p.status === 'Active' ? 'success' : p.status === 'Processing' ? 'warning' : p.status === 'Suspended' ? 'danger' : 'secondary' %>">
                                <%= p.status || '-' %>
                            </span>
                        </td>
                        <td>
                            <a href="/permits/<%= p.uuid %>" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye"></i>
                            </a>
                            <% if (user && user.permissions && user.permissions.includes('permits-edit')) { %>
                            <a href="/permits/<%= p.uuid %>/edit" class="btn btn-sm btn-outline-secondary">
                                <i class="fas fa-edit"></i>
                            </a>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (permits.length === 0) { %>
                    <tr><td colspan="7" class="text-center text-muted py-4">No permits found</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
document.getElementById('searchInput').addEventListener('keyup', function() {
    const value = this.value.toLowerCase();
    document.querySelectorAll('#permitsTable tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(value) ? '' : 'none';
    });
});
</script>