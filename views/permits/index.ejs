<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Permits</h1>
        <p class="text-muted mb-0"><%= total %> records found — showing page <%= page %> of <%= totalPages %></p>
    </div>
    <% if (user && user.permissions && user.permissions.includes('permits-add')) { %>
    <a href="/permits/create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Add Permit
    </a>
    <% } %>
</div>

<div class="card">
    <div class="card-body">

        <!-- SEARCH -->
        <div class="mb-2">
            <form method="GET" action="/permits" class="d-flex gap-2">
                <input type="text" name="search" class="form-control"
                       placeholder="Search by permit number, reference or applicant..."
                       value="<%= search %>">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search"></i>
                </button>
                <% if (search) { %>
                <a href="/permits" class="btn btn-outline-secondary"><i class="fas fa-times"></i></a>
                <% } %>
            </form>
        </div>

        <!-- FILTER -->
        <div class="mb-3">
            <form method="GET" action="/permits" class="row g-2">
                <div class="col-6 col-md-3">
                    <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">All Statuses</option>
                        <option value="Active" <%= locals.status == 'Active' ? 'selected' : '' %>>Active</option>
                        <option value="Processing" <%= locals.status == 'Processing' ? 'selected' : '' %>>Processing</option>
                        <option value="Suspended" <%= locals.status == 'Suspended' ? 'selected' : '' %>>Suspended</option>
                        <option value="Inactive" <%= locals.status == 'Inactive' ? 'selected' : '' %>>Inactive</option>
                        <option value="Expired" <%= locals.status == 'Expired' ? 'selected' : '' %>>Expired</option>
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <a href="/permits" class="btn btn-outline-secondary btn-sm w-100">
                        <i class="fas fa-times me-1"></i>Clear Filters
                    </a>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Permit No.</th>
                        <th>Applicant</th>
                        <th>Reference</th>
                        <th>Station</th>
                        <th>Issue Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% permits.forEach(p => { %>
                    <tr style="cursor:pointer;" ondblclick="window.location='/permits/<%= p.uuid %>'">
                        <td><%= p.permit_number || '-' %></td>
                        <td>
                            <% if (p.applicant_uuid) { %>
                                <a href="/applicants/<%= p.applicant_uuid %>" class="text-decoration-none"><%= p.applicant_name || '-' %></a>
                            <% } else { %>
                                <%= p.applicant_name || '-' %>
                            <% } %>
                        </td>
                        <td><%= p.reference_number || '-' %></td>
                        <td><%= p.range_name || '-' %></td>
                        <td><%= p.issue_date ? new Date(p.issue_date).toLocaleDateString() : '-' %></td>
                        <td>
                            <span class="badge bg-<%= p.status === 'Active' ? 'success' : p.status === 'Processing' ? 'warning' : p.status === 'Suspended' ? 'danger' : 'secondary' %>">
                                <%= p.status || '-' %>
                            </span>
                        </td>
                        <td>
                            <a href="/permits/<%= p.uuid %>" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye"></i>
                            </a>
                            <% if (user && user.permissions && user.permissions.includes('permits-edit')) { %>
                            <a href="/permits/<%= p.uuid %>/edit" class="btn btn-sm btn-outline-secondary">
                                <i class="fas fa-edit"></i>
                            </a>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (permits.length === 0) { %>
                    <tr><td colspan="7" class="text-center text-muted py-4">No permits found</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <% if (totalPages > 1) { %>
        <nav class="mt-3">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="/permits?page=<%= page - 1 %>&search=<%= search %>&status=<%= locals.status || '' %>">
                        <i class="fas fa-chevron-left"></i> Prev
                    </a>
                </li>
                <% for (let i = Math.max(1, page - 2); i <= Math.min(totalPages, page + 2); i++) { %>
                <li class="page-item <%= i === page ? 'active' : '' %>">
                    <a class="page-link" href="/permits?page=<%= i %>&search=<%= search %>&status=<%= locals.status || '' %>"><%= i %></a>
                </li>
                <% } %>
                <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
                    <a class="page-link" href="/permits?page=<%= page + 1 %>&search=<%= search %>&status=<%= locals.status || '' %>">
                        Next <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
            <p class="text-center text-muted small mt-2">
                Showing <%= (page - 1) * 30 + 1 %> — <%= Math.min(page * 30, total) %> of <%= total %> permits
            </p>
        </nav>
        <% } %>
    </div>
</div>