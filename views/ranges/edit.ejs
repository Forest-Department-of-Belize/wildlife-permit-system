<%- include('../layouts/main') %>
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Edit Station</h1>
    <a href="/ranges" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>
<form method="POST" action="/ranges/<%= range.uuid %>">
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Station Name</label>
                    <input type="text" name="name" class="form-control" value="<%= range.name %>">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">District</label>
                    <select name="district_id" class="form-select">
                        <option value="">Select District</option>
                        <% districts.forEach(d => { %>
                        <option value="<%= d.id %>" <%= range.district_id == d.id ? 'selected' : '' %>><%= d.name %></option>
                        <% }) %>
                    </select>
                </div>
            </div>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Update Station</button>
        <a href="/ranges" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>