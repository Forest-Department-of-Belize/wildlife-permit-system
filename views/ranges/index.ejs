
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Forest Stations</h1>
    <a href="/ranges/create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Add Station</a>
</div>
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead><tr><th>Station Name</th><th>District</th><th>Actions</th></tr></thead>
                <tbody>
                    <% ranges.forEach(r => { %>
                    <tr>
                        <td><%= r.name %></td>
                        <td><%= r.district_name || '-' %></td>
                        <td>
                            <a href="/ranges/<%= r.uuid %>" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a>
                            <a href="/ranges/<%= r.uuid %>/edit" class="btn btn-sm btn-outline-secondary"><i class="fas fa-edit"></i></a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>