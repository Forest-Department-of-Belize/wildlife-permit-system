<%- include('../layouts/main') %>
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Add Forest Station</h1>
    <a href="/ranges" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>
<form method="POST" action="/ranges">
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Station Name <span class="text-danger">*</span></label>
                    <input type="text" name="name" class="form-control" required>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">District</label>
                    <select name="district_id" class="form-select">
                        <option value="">Select District</option>
                        <% districts.forEach(d => { %>
                        <option value="<%= d.id %>"><%= d.name %></option>
                        <% }) %>
                    </select>
                </div>
            </div>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Save Station</button>
        <a href="/ranges" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>