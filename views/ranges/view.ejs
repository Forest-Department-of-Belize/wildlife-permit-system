
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title"><%= range.name %></h1>
    <div>
        <a href="/ranges/<%= range.uuid %>/edit" class="btn btn-outline-secondary me-2"><i class="fas fa-edit me-1"></i>Edit</a>
        <a href="/ranges" class="btn btn-outline-primary"><i class="fas fa-arrow-left me-1"></i>Back</a>
    </div>
</div>
<div class="row g-4">
    <div class="col-12 col-lg-4">
        <div class="card">
            <div class="card-header"><h6 class="mb-0">Station Details</h6></div>
            <div class="card-body">
                <table class="table table-borderless table-sm">
                    <tr><td class="text-muted">Name</td><td><%= range.name %></td></tr>
                    <tr><td class="text-muted">District</td><td><%= range.district_name || '-' %></td></tr>
                </table>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-8">
        <div class="row g-3">
            <div class="col-6">
                <div class="stat-card">
                    <div class="stat-icon bg-success"><i class="fas fa-file-alt"></i></div>
                    <div class="stat-info">
                        <h3><%= stats.active_permits %></h3>
                        <p>Active Permits</p>
                    </div>
                </div>
            </div>
            <div class="col-6">
                <div class="stat-card">
                    <div class="stat-icon bg-primary"><i class="fas fa-file-alt"></i></div>
                    <div class="stat-info">
                        <h3><%= stats.total_permits %></h3>
                        <p>Total Permits</p>
                    </div>
                </div>
            </div>
            <div class="col-6">
                <div class="stat-card">
                    <div class="stat-icon bg-warning"><i class="fas fa-search"></i></div>
                    <div class="stat-info">
                        <h3><%= stats.pending_inspections %></h3>
                        <p>Pending Inspections</p>
                    </div>
                </div>
            </div>
            <div class="col-6">
                <div class="stat-card">
                    <div class="stat-icon bg-secondary"><i class="fas fa-search"></i></div>
                    <div class="stat-info">
                        <h3><%= stats.total_inspections %></h3>
                        <p>Total Inspections</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>