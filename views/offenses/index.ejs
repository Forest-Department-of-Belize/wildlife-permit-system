<%- include('../layouts/main') %>
<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Compound Offenses</h1>
        <p class="text-muted mb-0"><%= offenses.length %> records found</p>
    </div>
    <% if (user && user.permissions && user.permissions.includes('offenses-add')) { %>
    <a href="/offenses/create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Add Offense</a>
    <% } %>
</div>
<div class="card">
    <div class="card-body">
        <div class="mb-3"><input type="text" id="searchInput" class="form-control" placeholder="Search offenses..."></div>
        <div class="table-responsive">
            <table class="table table-hover" id="dataTable">
                <thead><tr><th>Date</th><th>Applicant</th><th>Officer</th><th>Wildlife</th><th>Station</th><th>Actions</th></tr></thead>
                <tbody>
                    <% offenses.forEach(o => { %>
                    <tr>
                        <td><%= o.offense_date ? new Date(o.offense_date).toLocaleDateString() : '-' %></td>
                        <td><a href="/applicants/<%= o.applicant_uuid %>"><%= o.applicant_name || '-' %></a></td>
                        <td><%= o.officer_name || '-' %></td>
                        <td><%= o.illegal_wildlife ? o.illegal_wildlife.substring(0, 50) : '-' %></td>
                        <td><%= o.range_name || '-' %></td>
                        <td>
                            <a href="/offenses/<%= o.uuid %>" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a>
                            <% if (user && user.permissions && user.permissions.includes('offenses-edit')) { %>
                            <a href="/offenses/<%= o.uuid %>/edit" class="btn btn-sm btn-outline-secondary"><i class="fas fa-edit"></i></a>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (offenses.length === 0) { %>
                    <tr><td colspan="6" class="text-center text-muted py-4">No offenses found</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<script>
document.getElementById('searchInput').addEventListener('keyup', function() {
    const value = this.value.toLowerCase();
    document.querySelectorAll('#dataTable tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(value) ? '' : 'none';
    });
});
</script>