
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Add Compound Offense</h1>
    <a href="/offenses" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>
<form method="POST" action="/offenses">
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Applicant <span class="text-danger">*</span></label>
                    <select name="applicant_id" class="form-select" required>
                        <option value="">Select Applicant</option>
                        <% applicants.forEach(a => { %>
                        <option value="<%= a.id %>"><%= a.last_name %>, <%= a.first_name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Officer</label>
                    <select name="officer_id" class="form-select">
                        <option value="">Select Officer</option>
                        <% officers.forEach(o => { %>
                        <option value="<%= o.id %>"><%= o.first_name %> <%= o.last_name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Forest Station</label>
                    <select name="range_id" class="form-select">
                        <option value="">Select Station</option>
                        <% ranges.forEach(r => { %>
                        <option value="<%= r.id %>" <%= user.range_id == r.id ? 'selected' : '' %>><%= r.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Offense Date</label>
                    <input type="date" name="offense_date" class="form-control">
                </div>
                <div class="col-12">
                    <label class="form-label">Illegal Wildlife Description</label>
                    <textarea name="illegal_wildlife" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Cage Size (feet)</label>
                    <input type="text" name="cage_size_feet" class="form-control">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Cage Location</label>
                    <input type="text" name="cage_location" class="form-control">
                </div>
                <div class="col-12">
                    <label class="form-label">Reason for Confiscation</label>
                    <textarea name="reason_confiscated" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12">
                    <div class="row g-2">
                        <div class="col-6 col-md-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="hand_tame" id="handTame">
                                <label class="form-check-label" for="handTame">Hand Tame</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="prior_history" id="priorHistory">
                                <label class="form-check-label" for="priorHistory">Prior History</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="cage_confiscated" id="cageConf">
                                <label class="form-check-label" for="cageConf">Cage Confiscated</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="signed_officer" id="signedOfficer">
                                <label class="form-check-label" for="signedOfficer">Officer Signed</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="signed_offender" id="signedOffender">
                                <label class="form-check-label" for="signedOffender">Offender Signed</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Date Signed</label>
                    <input type="date" name="signed_date" class="form-control">
                </div>
                <div class="col-12">
                    <label class="form-label">Health Issues</label>
                    <textarea name="health_issues" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Diet Notes</label>
                    <textarea name="diet_notes" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Comments</label>
                    <textarea name="offense_comments" class="form-control" rows="2"></textarea>
                </div>
            </div>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Save Offense</button>
        <a href="/offenses" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>