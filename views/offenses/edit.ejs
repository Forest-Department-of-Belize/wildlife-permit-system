
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Edit Offense</h1>
    <a href="/offenses/<%= offense.uuid %>" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>
<form method="POST" action="/offenses/<%= offense.uuid %>">
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Officer</label>
                    <select name="officer_id" class="form-select">
                        <% officers.forEach(o => { %>
                        <option value="<%= o.id %>" <%= offense.officer_id == o.id ? 'selected' : '' %>><%= o.first_name %> <%= o.last_name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Forest Station</label>
                    <select name="range_id" class="form-select">
                        <% ranges.forEach(r => { %>
                        <option value="<%= r.id %>" <%= offense.range_id == r.id ? 'selected' : '' %>><%= r.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Offense Date</label>
                    <input type="date" name="offense_date" class="form-control"
                        value="<%= offense.offense_date ? new Date(offense.offense_date).toISOString().split('T')[0] : '' %>">
                </div>
                <div class="col-12">
                    <label class="form-label">Illegal Wildlife</label>
                    <textarea name="illegal_wildlife" class="form-control" rows="2"><%= offense.illegal_wildlife || '' %></textarea>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Reason for Confiscation</label>
                    <textarea name="reason_confiscated" class="form-control" rows="2"><%= offense.reason_confiscated || '' %></textarea>
                </div>
                <div class="col-12">
                    <div class="row g-2">
                        <div class="col-6 col-md-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="hand_tame"
                                    id="handTame" <%= offense.hand_tame ? 'checked' : '' %>>
                                <label class="form-check-label" for="handTame">Hand Tame</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="cage_confiscated"
                                    id="cageConf" <%= offense.cage_confiscated ? 'checked' : '' %>>
                                <label class="form-check-label" for="cageConf">Cage Confiscated</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="signed_officer"
                                    id="signedOfficer" <%= offense.signed_officer ? 'checked' : '' %>>
                                <label class="form-check-label" for="signedOfficer">Officer Signed</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="signed_offender"
                                    id="signedOffender" <%= offense.signed_offender ? 'checked' : '' %>>
                                <label class="form-check-label" for="signedOffender">Offender Signed</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Date Signed</label>
                    <input type="date" name="signed_date" class="form-control"
                        value="<%= offense.signed_date ? new Date(offense.signed_date).toISOString().split('T')[0] : '' %>">
                </div>
                <div class="col-12">
                    <label class="form-label">Comments</label>
                    <textarea name="offense_comments" class="form-control" rows="2"><%= offense.offense_comments || '' %></textarea>
                </div>
            </div>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Update Offense</button>
        <a href="/offenses/<%= offense.uuid %>" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>