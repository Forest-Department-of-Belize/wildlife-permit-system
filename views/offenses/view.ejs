
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Compound Offense Record</h1>
    <div>
        <% if (user && user.permissions && user.permissions.includes('offenses-edit')) { %>
        <a href="/offenses/<%= offense.uuid %>/edit" class="btn btn-outline-secondary me-2"><i class="fas fa-edit me-1"></i>Edit</a>
        <% } %>
        <a href="/offenses" class="btn btn-outline-primary"><i class="fas fa-arrow-left me-1"></i>Back</a>
    </div>
</div>
<div class="card">
    <div class="card-header"><h6 class="mb-0">Offense Details</h6></div>
    <div class="card-body">
        <div class="row">
            <div class="col-12 col-md-6">
                <table class="table table-borderless table-sm">
                    <tr><td class="text-muted">Applicant</td><td><a href="/applicants/<%= offense.applicant_uuid %>"><%= offense.applicant_name %></a></td></tr>
                    <tr><td class="text-muted">Officer</td><td><%= offense.officer_name || '-' %></td></tr>
                    <tr><td class="text-muted">Station</td><td><%= offense.range_name || '-' %></td></tr>
                    <tr><td class="text-muted">Date</td><td><%= offense.offense_date ? new Date(offense.offense_date).toLocaleDateString() : '-' %></td></tr>
                    <tr><td class="text-muted">Illegal Wildlife</td><td><%= offense.illegal_wildlife || '-' %></td></tr>
                    <tr><td class="text-muted">Hand Tame</td><td><%= offense.hand_tame ? 'Yes' : 'No' %></td></tr>
                    <tr><td class="text-muted">Date Acquired</td><td><%= offense.date_acquired ? new Date(offense.date_acquired).toLocaleDateString() : '-' %></td></tr>
                    <tr><td class="text-muted">Prior History</td><td><%= offense.prior_history ? 'Yes' : 'No' %></td></tr>
                </table>
            </div>
            <div class="col-12 col-md-6">
                <table class="table table-borderless table-sm">
                    <tr><td class="text-muted">Health Issues</td><td><%= offense.health_issues || '-' %></td></tr>
                    <tr><td class="text-muted">Diet Notes</td><td><%= offense.diet_notes || '-' %></td></tr>
                    <tr><td class="text-muted">Cage Size</td><td><%= offense.cage_size_feet || '-' %></td></tr>
                    <tr><td class="text-muted">Cage Confiscated</td><td><%= offense.cage_confiscated ? 'Yes' : 'No' %></td></tr>
                    <tr><td class="text-muted">Cage Location</td><td><%= offense.cage_location || '-' %></td></tr>
                    <tr><td class="text-muted">Reason</td><td><%= offense.reason_confiscated || '-' %></td></tr>
                    <tr><td class="text-muted">Officer Signed</td><td><%= offense.signed_officer ? 'Yes' : 'No' %></td></tr>
                    <tr><td class="text-muted">Offender Signed</td><td><%= offense.signed_offender ? 'Yes' : 'No' %></td></tr>
                    <tr><td class="text-muted">Signed Date</td><td><%= offense.signed_date ? new Date(offense.signed_date).toLocaleDateString() : '-' %></td></tr>
                </table>
            </div>
        </div>
        <% if (offense.offense_comments) { %>
        <div class="mt-3">
            <strong>Comments</strong>
            <p class="mt-1"><%= offense.offense_comments %></p>
        </div>
        <% } %>
    </div>
</div>