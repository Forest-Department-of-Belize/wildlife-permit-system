
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Edit Parrot</h1>
    <a href="/parrots/<%= parrot.uuid %>" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>
<form method="POST" action="/parrots/<%= parrot.uuid %>">
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Species</label>
                    <select name="species_id" class="form-select">
                        <option value="">Select Species</option>
                        <% species.forEach(s => { %>
                        <option value="<%= s.id %>" <%= parrot.species_id == s.id ? 'selected' : '' %>><%= s.common_name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Band Number</label>
                    <input type="text" name="band_number" class="form-control" value="<%= parrot.band_number || '' %>">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Pet Name</label>
                    <input type="text" name="pet_name" class="form-control" value="<%= parrot.pet_name || '' %>">
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Sex</label>
                    <select name="sex" class="form-select">
                        <option value="" <%= !parrot.sex ? 'selected' : '' %>>Unknown</option>
                        <option value="Male" <%= parrot.sex === 'Male' ? 'selected' : '' %>>Male</option>
                        <option value="Female" <%= parrot.sex === 'Female' ? 'selected' : '' %>>Female</option>
                    </select>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Age (months)</label>
                    <input type="number" name="parrot_age_months" class="form-control" value="<%= parrot.parrot_age_months || '' %>">
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Ownership (months)</label>
                    <input type="number" name="period_of_ownership_months" class="form-control" value="<%= parrot.period_of_ownership_months || '' %>">
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Method Obtained</label>
                    <input type="text" name="method_obtained" class="form-control" value="<%= parrot.method_obtained || '' %>">
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Has Parrot</label>
                    <select name="has_parrot" class="form-select">
                        <option value="Yes" <%= parrot.has_parrot === 'Yes' ? 'selected' : '' %>>Yes</option>
                        <option value="No" <%= parrot.has_parrot === 'No' ? 'selected' : '' %>>No</option>
                        <option value="Unknown" <%= parrot.has_parrot === 'Unknown' ? 'selected' : '' %>>Unknown</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Housing Details</label>
                    <textarea name="housing_details" class="form-control" rows="2"><%= parrot.housing_details || '' %></textarea>
                </div>
                <div class="col-12 col-md-6">
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" name="is_healthy"
                            id="isHealthy" <%= parrot.is_healthy ? 'checked' : '' %>>
                        <label class="form-check-label" for="isHealthy">Healthy</label>
                    </div>
                </div>
                <div class="col-12">
                    <label class="form-label">Health Comments</label>
                    <textarea name="health_comments" class="form-control" rows="2"><%= parrot.health_comments || '' %></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Stories</label>
                    <textarea name="stories" class="form-control" rows="2"><%= parrot.stories || '' %></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Bird Comments</label>
                    <textarea name="bird_comments" class="form-control" rows="2"><%= parrot.bird_comments || '' %></textarea>
                </div>
            </div>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Update Parrot</button>
        <a href="/parrots/<%= parrot.uuid %>" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>