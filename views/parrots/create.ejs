
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Add New Parrot</h1>
    <a href="/parrots" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>
<form method="POST" action="/parrots">
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Applicant <span class="text-danger">*</span></label>
                    <select name="applicant_id" class="form-select" required>
                        <option value="">Select Applicant</option>
                        <% applicants.forEach(a => { %>
                        <option value="<%= a.id %>"><%= a.last_name %>, <%= a.first_name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Species</label>
                    <select name="species_id" class="form-select">
                        <option value="">Select Species</option>
                        <% species.forEach(s => { %>
                        <option value="<%= s.id %>"><%= s.common_name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Band Number</label>
                    <input type="text" name="band_number" class="form-control">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Pet Name</label>
                    <input type="text" name="pet_name" class="form-control">
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Sex</label>
                    <select name="sex" class="form-select">
                        <option value="">Unknown</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Age (months)</label>
                    <input type="number" name="parrot_age_months" class="form-control" min="0">
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Ownership (months)</label>
                    <input type="number" name="period_of_ownership_months" class="form-control" min="0">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Method Obtained</label>
                    <input type="text" name="method_obtained" class="form-control">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Has Parrot</label>
                    <select name="has_parrot" class="form-select">
                        <option value="Yes">Yes</option>
                        <option value="No">No</option>
                        <option value="Unknown">Unknown</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Housing Details</label>
                    <textarea name="housing_details" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12 col-md-6">
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" name="is_healthy" id="isHealthy" checked>
                        <label class="form-check-label" for="isHealthy">Healthy</label>
                    </div>
                </div>
                <div class="col-12">
                    <label class="form-label">Health Comments</label>
                    <textarea name="health_comments" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Stories</label>
                    <textarea name="stories" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Bird Comments</label>
                    <textarea name="bird_comments" class="form-control" rows="2"></textarea>
                </div>
            </div>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Save Parrot</button>
        <a href="/parrots" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>