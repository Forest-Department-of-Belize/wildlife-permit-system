<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Parrots</h1>
        <p class="text-muted mb-0"><%= parrots.length %> records found</p>
    </div>
    <% if (user && user.permissions && user.permissions.includes('parrots-add')) { %>
    <a href="/parrots/create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Add Parrot
    </a>
    <% } %>
</div>
<div class="card">
    <div class="card-body">

        <!-- SEARCH -->
        <div class="mb-2">
            <form method="GET" action="/parrots" class="d-flex gap-2">
                <input type="text" name="search" class="form-control"
                       placeholder="Search by band number, name or species..."
                       value="<%= search %>">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search"></i>
                </button>
                <% if (search) { %>
                <a href="/parrots" class="btn btn-outline-secondary"><i class="fas fa-times"></i></a>
                <% } %>
            </form>
        </div>

        <!-- FILTER -->
        <div class="mb-3">
            <form method="GET" action="/parrots" class="row g-2">
                <div class="col-6 col-md-3">
                    <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">All Status</option>
                        <option value="active" <%= locals.parrotStatus == 'active' ? 'selected' : '' %>>Active</option>
                        <option value="confiscated" <%= locals.parrotStatus == 'confiscated' ? 'selected' : '' %>>Confiscated</option>
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <a href="/parrots" class="btn btn-outline-secondary btn-sm w-100">
                        <i class="fas fa-times me-1"></i>Clear Filters
                    </a>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Band No.</th>
                        <th>Name</th>
                        <th>Species</th>
                        <th>Applicant</th>
                        <th>Sex</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% parrots.forEach(p => { %>
                    <tr style="cursor:pointer;" ondblclick="window.location='/parrots/<%= p.uuid %>'">
                        <td><%= p.band_number || '-' %></td>
                        <td><%= p.pet_name || '-' %></td>
                        <td><%= p.species_name || '-' %></td>
                        <td><a href="/applicants/<%= p.applicant_uuid %>"><%= p.applicant_name || '-' %></a></td>
                        <td><%= p.sex || '-' %></td>
                        <td>
                            <span class="badge bg-<%= p.confiscated ? 'danger' : 'success' %>">
                                <%= p.confiscated ? 'Confiscated' : 'Active' %>
                            </span>
                        </td>
                        <td>
                            <a href="/parrots/<%= p.uuid %>" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye"></i>
                            </a>
                            <% if (user && user.permissions && user.permissions.includes('parrots-edit')) { %>
                            <a href="/parrots/<%= p.uuid %>/edit" class="btn btn-sm btn-outline-secondary">
                                <i class="fas fa-edit"></i>
                            </a>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (parrots.length === 0) { %>
                    <tr><td colspan="7" class="text-center text-muted py-4">No parrots found</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>