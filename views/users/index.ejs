<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Users</h1>
        <p class="text-muted mb-0"><%= users.length %> users found</p>
    </div>
    <% if (user && user.role === 'Wildlife Program Manager') { %>
    <a href="/users/create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Invite User</a>
    <% } %>
</div>
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Station</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(u => { %>
                    <tr>
                        <td><%= u.first_name %> <%= u.last_name %></td>
                        <td><%= u.email %></td>
                        <td><%= u.role || '-' %></td>
                        <td><%= u.range_name || 'All Stations' %></td>
                        <td>
                            <span class="badge bg-<%= u.is_active ? 'success' : 'secondary' %>">
                                <%= u.is_active ? 'Active' : 'Inactive' %>
                            </span>
                            <% if (u.invite_token) { %>
                            <span class="badge bg-warning ms-1">Pending Setup</span>
                            <% } %>
                        </td>
                        <td>
                            <a href="/users/<%= u.uuid %>" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a href="/users/<%= u.uuid %>/edit" class="btn btn-sm btn-outline-secondary">
                                <i class="fas fa-edit"></i>
                            </a>
                            <% if (u.invite_token && user.role === 'Wildlife Program Manager') { %>
                            <button class="btn btn-sm btn-outline-warning" title="Copy Setup Link"
                                    onclick="copySetupLink('<%= u.invite_token %>', '<%= u.first_name %>')">
                                <i class="fas fa-copy"></i>
                            </button>
                            <form method="POST" action="/users/<%= u.uuid %>/resend-invite" style="display:inline">
                                <button type="submit" class="btn btn-sm btn-outline-info" title="Resend Invite">
                                    <i class="fas fa-envelope"></i>
                                </button>
                            </form>
                            <% } %>
                            <% if (user.role === 'Wildlife Program Manager' && u.uuid !== user.uuid) { %>
                                <% if (u.is_active) { %>
                                <form method="POST" action="/users/<%= u.uuid %>/deactivate" style="display:inline"
                                      onsubmit="return confirm('Deactivate <%= u.first_name %> <%= u.last_name %>? They will be notified by email.')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Deactivate">
                                        <i class="fas fa-user-slash"></i>
                                    </button>
                                </form>
                                <% } else { %>
                                <form method="POST" action="/users/<%= u.uuid %>/reactivate" style="display:inline"
                                      onsubmit="return confirm('Reactivate <%= u.first_name %> <%= u.last_name %>?')">
                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Reactivate">
                                        <i class="fas fa-user-check"></i>
                                    </button>
                                </form>
                                <% } %>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (users.length === 0) { %>
                    <tr><td colspan="6" class="text-center text-muted py-4">No users found</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
function copySetupLink(token, name) {
    var url = window.location.origin + '/setup-account/' + token;
    if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(url).then(function() {
            alert('Setup link for ' + name + ' copied!\n\nSend via WhatsApp:\n' + url);
        }).catch(function() {
            prompt('Copy this link and send to ' + name + ' via WhatsApp:', url);
        });
    } else {
        prompt('Copy this link and send to ' + name + ' via WhatsApp:', url);
    }
}
</script>