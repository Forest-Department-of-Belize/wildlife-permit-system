
<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Users</h1>
        <p class="text-muted mb-0"><%= users.length %> users found</p>
    </div>
    <% if (user && user.role === 'Wildlife Program Manager') { %>
    <a href="/users/create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Invite User</a>
    <% } %>
</div>
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Station</th><th>Status</th><th>Actions</th></tr></thead>
                <tbody>
                    <% users.forEach(u => { %>
                    <tr>
                        <td><%= u.first_name %> <%= u.last_name %></td>
                        <td><%= u.email %></td>
                        <td><%= u.role || '-' %></td>
                        <td><%= u.range_name || 'All Stations' %></td>
                        <td>
                            <span class="badge bg-<%= u.is_active ? 'success' : 'secondary' %>">
                                <%= u.is_active ? 'Active' : 'Inactive' %>
                            </span>
                            <% if (u.invite_token) { %>
                            <span class="badge bg-warning ms-1">Pending Setup</span>
                            <% } %>
                        </td>
                        <td>
                            <a href="/users/<%= u.uuid %>" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a>
                            <a href="/users/<%= u.uuid %>/edit" class="btn btn-sm btn-outline-secondary"><i class="fas fa-edit"></i></a>
                            <% if (u.invite_token && user.role === 'Wildlife Program Manager') { %>
                            <form method="POST" action="/users/<%= u.uuid %>/resend-invite" style="display:inline">
                                <button type="submit" class="btn btn-sm btn-outline-info" title="Resend Invite">
                                    <i class="fas fa-envelope"></i>
                                </button>
                            </form>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (users.length === 0) { %>
                    <tr><td colspan="6" class="text-center text-muted py-4">No users found</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>