<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Applicants</h1>
        <p class="text-muted mb-0"><%= total %> records found — showing page <%= page %> of <%= totalPages %></p>
    </div>
    <% if (user && user.permissions && user.permissions.includes('applicants-add')) { %>
    <a href="/applicants/create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Add Applicant
    </a>
    <% } %>
</div>
<div class="card">
    <div class="card-body">
        <div class="mb-3">
            <form method="GET" action="/applicants" class="d-flex gap-2">
                <input type="text" name="search" class="form-control"
                       placeholder="Search by name, phone, email or ID..."
                       value="<%= search %>">
                <input type="hidden" name="sort" value="<%= sort %>">
                <input type="hidden" name="dir" value="<%= dir %>">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search"></i>
                </button>
                <% if (search) { %>
                <a href="/applicants" class="btn btn-outline-secondary">
                    <i class="fas fa-times"></i>
                </a>
                <% } %>
            </form>
        </div>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>
                            <a href="/applicants?page=1&search=<%= search %>&sort=last_name&dir=<%= sort === 'last_name' && dir === 'asc' ? 'desc' : 'asc' %>" class="text-dark text-decoration-none">
                                Name <i class="fas fa-sort<%= sort === 'last_name' ? (dir === 'asc' ? '-up' : '-down') : '' %> ms-1"></i>
                            </a>
                        </th>
                        <th>Contact</th>
                        <th>
                            <a href="/applicants?page=1&search=<%= search %>&sort=district_name&dir=<%= sort === 'district_name' && dir === 'asc' ? 'desc' : 'asc' %>" class="text-dark text-decoration-none">
                                District <i class="fas fa-sort<%= sort === 'district_name' ? (dir === 'asc' ? '-up' : '-down') : '' %> ms-1"></i>
                            </a>
                        </th>
                        <th>Status</th>
                        <th>Inspection</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% applicants.forEach(a => { %>
                    <tr>
                        <td>
                            <strong><%= a.last_name %>, <%= a.first_name %></strong>
                            <% if (a.middle_name) { %>
                                <span class="text-muted"> <%= a.middle_name %></span>
                            <% } %>
                        </td>
                        <td>
                            <%= a.contact_number || '-' %>
                            <% if (a.contact_number_whatsapp) { %>
                                <i class="fab fa-whatsapp text-success ms-1"></i>
                            <% } %>
                        </td>
                        <td><%= a.district_name || '-' %></td>
                        <td>
                            <%
                            const psMap = {
                                'Pending Call': 'secondary',
                                'Called': 'info',
                                'Inspection Booked': 'warning',
                                'Inspection Done': 'primary',
                                'Pending Compliance': 'danger',
                                'Approved Awaiting Banding': 'success',
                                'Approved': 'success',
                                'Rejected': 'dark'
                            };
                            const psColor = psMap[a.process_status] || 'secondary';
                            %>
                            <span class="badge bg-<%= psColor %>"><%= a.process_status || 'Pending Call' %></span>
                        </td>
                        <td>
                            <% if (parseInt(a.pending_inspection_count) > 0) { %>
                                <small class="text-warning"><i class="fas fa-calendar-check me-1"></i><%= a.pending_inspector || 'Unassigned' %></small>
                            <% } else { %>
                                <span class="text-muted small">—</span>
                            <% } %>
                        </td>
                        <td>
                            <a href="/applicants/<%= a.uuid %>" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye"></i>
                            </a>
                            <% if (user && user.permissions && user.permissions.includes('applicants-edit')) { %>
                            <a href="/applicants/<%= a.uuid %>/edit" class="btn btn-sm btn-outline-secondary">
                                <i class="fas fa-edit"></i>
                            </a>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (applicants.length === 0) { %>
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No applicants found</td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
        <nav class="mt-3">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="/applicants?page=<%= page - 1 %>&search=<%= search %>&sort=<%= sort %>&dir=<%= dir %>">
                        <i class="fas fa-chevron-left"></i> Prev
                    </a>
                </li>
                <% for (let i = Math.max(1, page - 2); i <= Math.min(totalPages, page + 2); i++) { %>
                <li class="page-item <%= i === page ? 'active' : '' %>">
                    <a class="page-link" href="/applicants?page=<%= i %>&search=<%= search %>&sort=<%= sort %>&dir=<%= dir %>"><%= i %></a>
                </li>
                <% } %>
                <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
                    <a class="page-link" href="/applicants?page=<%= page + 1 %>&search=<%= search %>&sort=<%= sort %>&dir=<%= dir %>">
                        Next <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
            <p class="text-center text-muted small mt-2">
                Showing <%= (page - 1) * 30 + 1 %> — <%= Math.min(page * 30, total) %> of <%= total %> applicants
            </p>
        </nav>
        <% } %>
    </div>
</div>