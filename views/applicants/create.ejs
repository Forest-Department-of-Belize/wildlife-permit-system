<%- include('../layouts/main') %>
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Add New Applicant</h1>
    <a href="/applicants" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i>Back
    </a>
</div>

<form method="POST" action="/applicants">
    <div class="row g-4">
        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header"><h6 class="mb-0">Personal Information</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <label class="form-label">First Name <span class="text-danger">*</span></label>
                            <input type="text" name="first_name" class="form-control" required>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">Middle Name</label>
                            <input type="text" name="middle_name" class="form-control">
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">Last Name <span class="text-danger">*</span></label>
                            <input type="text" name="last_name" class="form-control" required>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Date of Birth</label>
                            <input type="date" name="date_of_birth" class="form-control">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">District</label>
                            <select name="district_id" class="form-select">
                                <option value="">Select District</option>
                                <% districts.forEach(d => { %>
                                <option value="<%= d.id %>"><%= d.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Address Line 1</label>
                            <input type="text" name="address1" class="form-control">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Address Line 2</label>
                            <input type="text" name="address2" class="form-control">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Primary Phone</label>
                            <input type="text" name="contact_number" class="form-control">
                        </div>
                        <div class="col-12 col-md-6 d-flex align-items-end">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="contact_number_whatsapp" id="whatsapp1">
                                <label class="form-check-label" for="whatsapp1">WhatsApp</label>
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Secondary Phone</label>
                            <input type="text" name="contact_number_secondary" class="form-control">
                        </div>
                        <div class="col-12 col-md-6 d-flex align-items-end">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="contact_number_secondary_whatsapp" id="whatsapp2">
                                <label class="form-check-label" for="whatsapp2">WhatsApp</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Email</label>
                            <input type="email" name="email" class="form-control">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Occupation</label>
                            <input type="text" name="occupation" class="form-control">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Company</label>
                            <input type="text" name="company" class="form-control">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Government ID Type</label>
                            <select name="government_id_type" class="form-select">
                                <option value="">Select Type</option>
                                <option value="Social Security">Social Security</option>
                                <option value="Passport">Passport</option>
                                <option value="Voter ID">Voter ID</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Government ID Number</label>
                            <input type="text" name="government_id_number" class="form-control">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header"><h6 class="mb-0">Housing & Care Details</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Parrot Diet</label>
                            <input type="text" name="parrot_diet" class="form-control">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Enclosure Type</label>
                            <input type="text" name="enclosure_type" class="form-control">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Cage Size (feet)</label>
                            <input type="text" name="cage_size_feet" class="form-control">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Cage Location</label>
                            <input type="text" name="cage_location" class="form-control">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Shared or Separate</label>
                            <input type="text" name="shared_separate" class="form-control">
                        </div>
                        <div class="col-12 col-md-4">
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" name="does_fly_free" id="flyFree">
                                <label class="form-check-label" for="flyFree">Flies Free</label>
                            </div>
                        </div>
                        <div class="col-12 col-md-4">
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" name="are_wings_cut" id="wingsCut">
                                <label class="form-check-label" for="wingsCut">Wings Cut</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">When Does It Fly Free</label>
                            <input type="text" name="fly_free_when" class="form-control">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Applicant Comments</label>
                            <textarea name="applicant_comments" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Ownership Comments</label>
                            <textarea name="ownership_comments" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Status</label>
                            <select name="applicant_status" class="form-select">
                                <option value="">Select Status</option>
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                                <option value="Pending">Pending</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Info Source</label>
                            <select name="info_source" class="form-select">
                                <option value="">Select Source</option>
                                <option value="Call">Call</option>
                                <option value="Historic">Historic</option>
                                <option value="Walk-in">Walk-in</option>
                                <option value="Referral">Referral</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save me-2"></i>Save Applicant
        </button>
        <a href="/applicants" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>