<div class="page-header">
    <h1 class="page-title">Import Historical Data</h1>
    <p class="text-muted">Upload the Excel file to import all historical records into the database.</p>
</div>

<div class="row g-4">
    <div class="col-12 col-lg-6">
        <div class="card">
            <div class="card-header"><h6 class="mb-0">Upload Excel File</h6></div>
            <div class="card-body">
                <form method="POST" action="/import" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label">Select Excel File (.xlsx)</label>
                        <input type="file" name="file" class="form-control" accept=".xlsx" required>
                        <div class="form-text">
                            Upload the Parrot_Data_Deliverable_UBERI.xlsx file.
                            The import will process Applicants, Applications, Permits and Parrots.
                        </div>
                    </div>
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        This will add all records from the file into the database.
                        Records that already exist will be skipped automatically.
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-upload me-2"></i>Start Import
                    </button>
                </form>
            </div>
        </div>
    </div>

    <% if (results) { %>
    <div class="col-12 col-lg-6">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h6 class="mb-0">Import Results</h6>
            </div>
            <div class="card-body">
                <table class="table table-sm mb-3">
                    <tr><td>Applicants imported</td><td><strong class="text-success"><%= results.applicants %></strong></td></tr>
                    <tr><td>Applications imported</td><td><strong class="text-success"><%= results.applications %></strong></td></tr>
                    <tr><td>Permits imported</td><td><strong class="text-success"><%= results.permits %></strong></td></tr>
                    <tr><td>Parrots imported</td><td><strong class="text-success"><%= results.parrots %></strong></td></tr>
                </table>

                <% if (results.errors.length > 0) { %>
                <div class="alert alert-warning">
                    <strong><%= results.errors.length %> warnings during import:</strong>
                    <div style="max-height:200px;overflow-y:auto;margin-top:8px;font-size:12px;">
                        <% results.errors.slice(0, 20).forEach(e => { %>
                        <div><%= e %></div>
                        <% }) %>
                        <% if (results.errors.length > 20) { %>
                        <div class="text-muted">...and <%= results.errors.length - 20 %> more</div>
                        <% } %>
                    </div>
                </div>
                <% } else { %>
                <div class="alert alert-success">
                    <i class="fas fa-check-circle me-2"></i>Import completed with no errors!
                </div>
                <% } %>
            </div>
        </div>
    </div>
    <% } %>
</div>