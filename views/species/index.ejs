<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Parrot Species</h1>
    <% if (user && user.permissions && user.permissions.includes('species-add')) { %>
    <a href="/species/create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Add Species</a>
    <% } %>
</div>
<div class="row g-4">
    <% species.forEach(s => { %>
    <div class="col-12 col-sm-6 col-lg-4">
        <div class="card h-100">
            <% if (s.image_url) { %>
            <img src="<%= s.image_url %>" class="card-img-top"
                 style="height:200px;object-fit:cover;"
                 onerror="this.src='/images/no-bird.jpg'">
            <% } else { %>
            <div class="card-img-top bg-light d-flex align-items-center justify-content-center"
                 style="height:200px;">
                <i class="fas fa-dove text-muted" style="font-size:60px;"></i>
            </div>
            <% } %>
            <div class="card-body">
                <h5 class="card-title mb-1"><%= s.common_name %></h5>
                <p class="text-muted small fst-italic mb-3"><%= s.scientific_name || 'Scientific name not recorded' %></p>
                <div class="d-flex gap-2">
                    <a href="/species/<%= s.uuid %>" class="btn btn-sm btn-outline-primary flex-fill">
                        <i class="fas fa-eye me-1"></i>View
                    </a>
                    <% if (user && user.permissions && user.permissions.includes('species-edit')) { %>
                    <a href="/species/<%= s.uuid %>/edit" class="btn btn-sm btn-outline-secondary flex-fill">
                        <i class="fas fa-edit me-1"></i>Edit
                    </a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
    <% }) %>
    <% if (species.length === 0) { %>
    <div class="col-12">
        <p class="text-center text-muted">No species recorded yet.</p>
    </div>
    <% } %>
</div>