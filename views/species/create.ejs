<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Add New Species</h1>
    <a href="/species" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>
<form method="POST" action="/species" enctype="multipart/form-data">
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Common Name <span class="text-danger">*</span></label>
                    <input type="text" name="common_name" class="form-control" required>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Scientific Name</label>
                    <input type="text" name="scientific_name" class="form-control">
                </div>
                <div class="col-12">
                    <label class="form-label">Upload Bird Image</label>
                    <input type="file" name="image_file" class="form-control" accept="image/*">
                    <div class="form-text">Upload a photo of this species (JPG, PNG, WebP — max 5MB)</div>
                </div>
                <div class="col-12">
                    <label class="form-label">Or paste an image URL</label>
                    <input type="text" name="image_url" class="form-control"
                           placeholder="https://example.com/bird.jpg">
                    <div class="form-text">If you upload a file above, the URL will be ignored.</div>
                </div>
            </div>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Save Species</button>
        <a href="/species" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>