<%- include('../layouts/main') %>
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title"><%= species.common_name %></h1>
    <div>
        <% if (user && user.permissions && user.permissions.includes('species-edit')) { %>
        <a href="/species/<%= species.uuid %>/edit" class="btn btn-outline-secondary me-2"><i class="fas fa-edit me-1"></i>Edit</a>
        <% } %>
        <a href="/species" class="btn btn-outline-primary"><i class="fas fa-arrow-left me-1"></i>Back</a>
    </div>
</div>
<div class="card">
    <div class="card-body">
        <table class="table table-borderless">
            <tr><td class="text-muted">Common Name</td><td><%= species.common_name %></td></tr>
            <tr><td class="text-muted">Scientific Name</td><td><em><%= species.scientific_name || '-' %></em></td></tr>
        </table>
    </div>
</div>