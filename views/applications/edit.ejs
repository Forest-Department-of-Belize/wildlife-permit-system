
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Edit Application</h1>
    <a href="/applications/<%= application.uuid %>" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>
<form method="POST" action="/applications/<%= application.uuid %>">
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Forest Station</label>
                    <select name="range_id" class="form-select">
                        <% ranges.forEach(r => { %>
                        <option value="<%= r.id %>" <%= application.range_id == r.id ? 'selected' : '' %>><%= r.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Reference Number</label>
                    <input type="text" name="reference_number" class="form-control" value="<%= application.reference_number || '' %>">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Status</label>
                    <select name="application_status" class="form-select">
                        <option value="Pending" <%= application.application_status === 'Pending' ? 'selected' : '' %>>Pending</option>
                        <option value="Approved" <%= application.application_status === 'Approved' ? 'selected' : '' %>>Approved</option>
                        <option value="Rejected" <%= application.application_status === 'Rejected' ? 'selected' : '' %>>Rejected</option>
                        <option value="Permit Awarded" <%= application.application_status === 'Permit Awarded' ? 'selected' : '' %>>Permit Awarded</option>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Application Date</label>
                    <input type="date" name="application_date" class="form-control"
                        value="<%= application.application_date ? new Date(application.application_date).toISOString().split('T')[0] : '' %>">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Date Received</label>
                    <input type="date" name="date_received" class="form-control"
                        value="<%= application.date_received ? new Date(application.date_received).toISOString().split('T')[0] : '' %>">
                </div>
                <div class="col-12 col-md-3">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" name="application_signed"
                            id="appSigned" <%= application.application_signed ? 'checked' : '' %>>
                        <label class="form-check-label" for="appSigned">Signed</label>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" name="applied_previously"
                            id="appliedPrev" <%= application.applied_previously ? 'checked' : '' %>>
                        <label class="form-check-label" for="appliedPrev">Applied Previously</label>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" name="previously_approved"
                            id="prevApproved" <%= application.previously_approved ? 'checked' : '' %>>
                        <label class="form-check-label" for="prevApproved">Previously Approved</label>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" name="followup_done"
                            id="followupDone" <%= application.followup_done ? 'checked' : '' %>>
                        <label class="form-check-label" for="followupDone">Followup Done</label>
                    </div>
                </div>
                <div class="col-12">
                    <label class="form-label">Followup Details</label>
                    <textarea name="followup_details" class="form-control" rows="2"><%= application.followup_details || '' %></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Comments</label>
                    <textarea name="application_comments" class="form-control" rows="2"><%= application.application_comments || '' %></textarea>
                </div>
            </div>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Update Application</button>
        <a href="/applications/<%= application.uuid %>" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>