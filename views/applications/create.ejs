
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">New Application</h1>
    <a href="/applications" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>
<form method="POST" action="/applications">
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Applicant <span class="text-danger">*</span></label>
                    <select name="applicant_id" class="form-select" required>
                        <option value="">Select Applicant</option>
                        <% applicants.forEach(a => { %>
                        <option value="<%= a.id %>"><%= a.last_name %>, <%= a.first_name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Forest Station</label>
                    <select name="range_id" class="form-select">
                        <option value="">Select Station</option>
                        <% ranges.forEach(r => { %>
                        <option value="<%= r.id %>" <%= user.range_id == r.id ? 'selected' : '' %>><%= r.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Reference Number</label>
                    <input type="text" name="reference_number" class="form-control">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Status</label>
                    <select name="application_status" class="form-select">
                        <option value="Pending">Pending</option>
                        <option value="Approved">Approved</option>
                        <option value="Rejected">Rejected</option>
                        <option value="Permit Awarded">Permit Awarded</option>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Application Date</label>
                    <input type="date" name="application_date" class="form-control">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Date Received</label>
                    <input type="date" name="date_received" class="form-control">
                </div>
                <div class="col-12 col-md-3">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" name="application_signed" id="appSigned">
                        <label class="form-check-label" for="appSigned">Signed</label>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" name="applied_previously" id="appliedPrev">
                        <label class="form-check-label" for="appliedPrev">Applied Previously</label>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" name="previously_approved" id="prevApproved">
                        <label class="form-check-label" for="prevApproved">Previously Approved</label>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" name="followup_done" id="followupDone">
                        <label class="form-check-label" for="followupDone">Followup Done</label>
                    </div>
                </div>
                <div class="col-12">
                    <label class="form-label">Followup Details</label>
                    <textarea name="followup_details" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Comments</label>
                    <textarea name="application_comments" class="form-control" rows="2"></textarea>
                </div>
            </div>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Save Application</button>
        <a href="/applications" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>