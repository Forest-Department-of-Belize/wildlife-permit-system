
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Districts</h1>
    <a href="/districts/create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Add District</a>
</div>
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead><tr><th>Name</th><th>Actions</th></tr></thead>
                <tbody>
                    <% districts.forEach(d => { %>
                    <tr>
                        <td><%= d.name %></td>
                        <td>
                            <a href="/districts/<%= d.uuid %>/edit" class="btn btn-sm btn-outline-secondary"><i class="fas fa-edit"></i></a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>