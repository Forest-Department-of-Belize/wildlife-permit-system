
<div class="page-header d-flex justify-content-between align-items-center">
    <h1 class="page-title">Add District</h1>
    <a href="/districts" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>
<form method="POST" action="/districts">
    <div class="card">
        <div class="card-body">
            <div class="col-12 col-md-6">
                <label class="form-label">District Name <span class="text-danger">*</span></label>
                <input type="text" name="name" class="form-control" required>
            </div>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Save District</button>
        <a href="/districts" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>